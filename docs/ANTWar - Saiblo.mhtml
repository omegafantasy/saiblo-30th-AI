.vm-select-icon-caret-top, .vm-select-icon-circle-close { display: inline-b=
lock; font-size: 16px; font-style: normal; -webkit-font-smoothing: antialia=
sed; font-family: vm-select-font !important; }

.vm-select-icon-caret-top::before { content: "=EE=9E=92"; }

.vm-select-icon-circle-close::before { content: "=EE=98=94"; }

.vm-select-input__inner { width: 240px; }

.vm-select { display: inline-block; position: relative; }

.vm-select:hover .vm-input__inner { border-color: rgb(131, 145, 165); }

.vm-select .vm-input__inner { cursor: pointer; padding-right: 35px; }

.vm-select .vm-input__inner:focus { border-color: rgb(32, 160, 255); }

.vm-select .vm-input .vm-input__icon { color: rgb(191, 203, 217); font-size=
: 12px; transition: transform 0.3s; transform: translateY(-50%) rotateZ(0de=
g); line-height: 16px; top: 50%; cursor: pointer; }

.vm-select .vm-input .vm-input__icon.reverse { transform: translateY(-50%) =
rotateZ(180deg); }

.vm-select .vm-input .vm-input__icon.show-close { transition: all; size: 16=
px; font-size: 14px; text-align: center; transform: translateY(-50%) rotate=
Z(0deg); border-radius: 100%; color: rgb(191, 203, 217); }

.vm-select .vm-input .vm-input__icon.show-close:hover { color: rgb(151, 168=
, 190); }

.vm-select .vm-input.is-disabled .vm-input__inner { cursor: not-allowed; }

.vm-select .vm-input.is-disabled .vm-input__inner:hover { border-color: rgb=
(209, 219, 229); }

.vm-select > .vm-input { display: block; }

.vm-select__input { border: none; outline: none; padding: 0px; margin-left:=
 10px; color: rgb(102, 102, 102); font-size: 14px; vertical-align: baseline=
; appearance: none; height: 28px; background-color: transparent; }

.vm-select__input.mini { height: 14px; }

.vm-select__close { cursor: pointer; position: absolute; top: 8px; z-index:=
 1000; right: 25px; color: rgb(191, 203, 217); line-height: 18px; font-size=
: 12px; }

.vm-select__close:hover { color: rgb(151, 168, 190); }

.vm-select__tags { position: absolute; line-height: normal; white-space: no=
rmal; z-index: 1; top: 50%; transform: translateY(-50%); }

.vm-select .vm-tag__close { margin-top: -2px; }

.vm-select .vm-tag { height: 24px; line-height: 24px; box-sizing: border-bo=
x; margin: 3px 0px 3px 6px; }

.vm-select__tag { display: inline-block; height: 24px; line-height: 24px; f=
ont-size: 14px; border-radius: 4px; color: rgb(255, 255, 255); background-c=
olor: rgb(32, 160, 255); }

.vm-select__tag .vm-tag-icon-close { font-size: 30px; }

.vm-select-dropdown__item { font-size: 14px; padding: 8px 10px; position: r=
elative; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; co=
lor: rgb(72, 87, 106); height: 36px; line-height: 1.5; box-sizing: border-b=
ox; cursor: pointer; }

.vm-select-dropdown__item.disabled { color: rgb(191, 203, 217); cursor: not=
-allowed; }

.vm-select-dropdown__item.disabled:hover { background-color: rgb(255, 255, =
255); }

.vm-select-dropdown__item.hover, .vm-select-dropdown__item:hover { backgrou=
nd-color: rgb(228, 232, 241); }

.vm-select-dropdown__item.selected { color: rgb(255, 255, 255); background-=
color: rgb(32, 160, 255); }

.vm-select-dropdown__item.selected.hover { background-color: rgb(28, 141, 2=
24); }

.vm-select-dropdown__item span { line-height: 1.5 !important; }

.vm-select-group { margin: 0px; padding: 0px; }

.vm-select-group__wrap { list-style: none; margin: 0px; padding: 0px; }

.vm-select-group__title { padding-left: 10px; font-size: 12px; color: rgb(1=
53, 153, 153); height: 30px; line-height: 30px; }

.vm-select-group .vm-select-dropdown__item { padding-left: 20px; }

.vm-select-dropdown { position: absolute; z-index: 1001; border: 1px solid =
rgb(209, 219, 229); border-radius: 2px; background-color: rgb(255, 255, 255=
); box-shadow: rgba(0, 0, 0, 0.12) 0px 2px 4px, rgba(0, 0, 0, 0.04) 0px 0px=
 6px; box-sizing: border-box; margin: 5px 0px; }

.vm-select-dropdown.multiple .vm-select-dropdown__item.selected { color: rg=
b(32, 160, 255); background-color: rgb(255, 255, 255); }

.vm-select-dropdown.multiple .vm-select-dropdown__item.selected.hover { bac=
kground-color: rgb(228, 232, 241); }

.vm-select-dropdown.multiple .vm-select-dropdown__item.selected::after { po=
sition: absolute; right: 10px; font-family: vm-select-font; content: "=EE=
=98=BE"; font-size: 11px; -webkit-font-smoothing: antialiased; }

.vm-select-dropdown .vm-scrollbar.is-empty .vm-select-dropdown__list { padd=
ing: 0px; }

.vm-select-dropdown__empty { padding: 10px 0px; margin: 0px; text-align: ce=
nter; color: rgb(153, 153, 153); font-size: 14px; }

.vm-select-dropdown__wrap { max-height: 274px; }

.vm-select-dropdown__list { list-style: none; padding: 6px 0px; margin: 0px=
; box-sizing: border-box; }
